PORT=8080
NODE_ENV=development
DATABASE_URL=mongodb://127.0.0.1:27017/medipulse
TOKEN_KEY=change-me
CLIENT_URLS=http://localhost:5173

RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=xxxxx
APPOINTMENT_FEE_INR=199

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-app-password
MAIL_FROM="MediPulse <your-email@example.com>"
RESEND_API_KEY=your-resend-api-key
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=your-verified-brevo-sender@example.com
BREVO_SENDER_NAME=MediPulse

REDIS_URL=redis://127.0.0.1:6379
AUTO_REFUND_WORKER_INTERVAL_MS=60000
ADMIN_USER_IDS=
VPAY_RATE_LIMIT_MAX=30
VPAY_RATE_LIMIT_WINDOW_SEC=60

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=medipulse-api
KAFKA_APPOINTMENT_TOPIC=medipulse.appointments
KAFKA_VPAY_CONSUMER_GROUP=medipulse-vpay-consumers
KAFKA_PAYMENTS_CREATED_TOPIC=payments.created
KAFKA_PAYMENTS_COMPLETED_TOPIC=payments.completed
KAFKA_PAYMENTS_FAILED_TOPIC=payments.failed
KAFKA_REFUNDS_CREATED_TOPIC=refunds.created
KAFKA_REFUNDS_COMPLETED_TOPIC=refunds.completed
KAFKA_WALLET_UPDATED_TOPIC=wallet.updated
KAFKA_NOTIFICATIONS_CREATED_TOPIC=notifications.created
KAFKA_ANALYTICS_EVENTS_TOPIC=analytics.events
KAFKA_SSL=false
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SASL_MECHANISM=plain
